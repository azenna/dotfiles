(defvar eww "eww -c .")

(defwidget bar []
  (box :orientation "h"
    (workspaces)
    (stats)))

(defwidget stats []
  (box :orientation "h" :valign "center" :halign "end" :space-evenly false
    (timebox)
    (battery)))

(defvar show_time false)

(defpoll time :interval "10s"
  "date '+%H:%M %b %d, %Y'")

(defwidget timebox []
  (eventbox
    :onhover "${eww} update show_time=true"
    :onhoverlost "${eww} update show_time=false"
    (box :space-evenly false :class "mr20 text-large color-mauve"
      (label :text "")
      (revealer
        :transition "slideleft"
        :reveal show_time
        (label :class "ml20" :text time)))))
      

(defvar show_bat false)

(defwidget battery []
  (eventbox
    :onhover "${eww} update show_bat=true"
    :onhoverlost "${eww} update show_bat=false"
    (box :space-evenly false :class "mr20 text-large color-red"
      (label :text "")
      (revealer 
        :reveal show_bat
        :transition "slideleft"
        (label :class "ml20" :text "${EWW_BATTERY["BAT0"].capacity}%")))))


(deflisten workspaces :initial "[]" "eww_workspaces")
(deflisten current_workspace :initial "1" "eww_active_workspace")

(defvar colors "[
  \"mauve\",
  \"red\",
  \"maroon\",
  \"peach\",
  \"yellow\",
  \"green\",
  \"teal\",
  \"sky\",
  \"sapphire\",
  \"blue\"
]")

(defwidget workspaces []
  (box :space-evenly true
    (for workspace in workspaces
      (label :class "color-${colors[workspace.id - 1]} ${workspace.id == current_workspace ? "active" : ""}" 
             :text " "))
    (label :visible false :text "${current_workspace}")))


(defwindow bar
  :monitor 0
  :windowtype "dock"
  :exclusive true
  :geometry (geometry :x "0%"
                      :y "0%"
                      :width "100%"
                      :height "3%"
                      :anchor "top center")
  (bar))
